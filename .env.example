# Telegram Bot (obtén el token con @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MercadoLibre API (opcional - si lo dejas vacío usa scraping)
# Regístrate gratis en https://developers.mercadolibre.com.mx
ML_CLIENT_ID=your_ml_client_id
ML_CLIENT_SECRET=your_ml_client_secret

# Intervalo de check por defecto (en horas)
DEFAULT_CHECK_INTERVAL=1
